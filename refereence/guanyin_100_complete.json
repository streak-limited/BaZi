[
  {
    "id": 1,
    "level": "上上",
    "poem": "開天闢地作良緣，吉日良時萬物全。若得此籤非小可，福如東海壽如山。",
    "allusion": "盤古開天"
  },
  {
    "id": 2,
    "level": "上吉",
    "poem": "欲求勝事總成空，遠處求財未得同。且守身心靜處坐，白雲依舊抱青松。",
    "allusion": "蘇秦不第"
  },
  {
    "id": 3,
    "level": "下下",
    "poem": "臨風冒雨去還歸，局促安能出範圍。折翼雄鷹傷羽羽，這回迷卻向南飛。",
    "allusion": "董永遇仙"
  },
  {
    "id": 4,
    "level": "上吉",
    "poem": "千年古鏡復重圓，女過男歸是本緣。風靜浪平蓮霧散，從今不日見青天。",
    "allusion": "破鏡重圓"
  },
  {
    "id": 5,
    "level": "中平",
    "poem": "一春萬事苦憂煎，夏裏風清漸自然。更向秋深圓月夜，涼風相送步青天。",
    "allusion": "劉晨遇仙"
  },
  {
    "id": 6,
    "level": "中平",
    "poem": "投身岩下銅鳥居，風雨淋漓總不知。翻身直上青雲路，方知始有運來時。",
    "allusion": "仁宗認母"
  },
  {
    "id": 7,
    "level": "下下",
    "poem": "奔波阻隔重重險，帶水拖泥步步難。若得貴人相引手，方知此去渡難關。",
    "allusion": "廉頗負荊"
  },
  {
    "id": 8,
    "level": "上上",
    "poem": "茂林深蔭鳳凰巢，引得仙人到此交。好事連連皆不盡，君當從此顯英豪。",
    "allusion": "薛仁貴回窯"
  },
  {
    "id": 9,
    "level": "中平",
    "poem": "勞心費力欲何求，寸步如登萬里秋。不如歇手閉門坐，免得隨風起閒愁。",
    "allusion": "趙韓王半部論語"
  },
  {
    "id": 10,
    "level": "下下",
    "poem": "石藏美玉何足觀，燒盡柴薪始見真。大抵黃金埋土內，不知何日見光明。",
    "allusion": "龐涓觀陣"
  },
  {
    "id": 11,
    "level": "上吉",
    "poem": "欲求富貴轉傷神，勞心力苦不知因。可把身心靜處坐，白雲依舊抱青松。",
    "allusion": "劉備求賢"
  },
  {
    "id": 12,
    "level": "上上",
    "poem": "長江浪暖魚自躍，恰似綉簾開晚妝。得此卦爻非小可，從今顯耀改門墻。",
    "allusion": "武吉賣柴遇文王"
  },
  {
    "id": 13,
    "level": "中平",
    "poem": "自小生身富貴家，眼前事事總繁華。要知此去前程路，一到秋深見際涯。",
    "allusion": "信陵君存趙"
  },
  {
    "id": 14,
    "level": "下下",
    "poem": "宛如孤鶴離開群，萬里翱翔入白雲。雖然不受機關網，爭奈身孤冷寂寞。",
    "allusion": "郭華醉臥胭脂巷"
  },
  {
    "id": 15,
    "level": "中平",
    "poem": "行人流水兩無情，兩隻扁舟各自行。急流灘上難安穩，勸君切莫過前程。",
    "allusion": "蘇秦說六國"
  },
  {
    "id": 16,
    "level": "中平",
    "poem": "營謀不願意如心，此處何須苦認真。爭如靜坐閉門睡，免得隨風起閒愁。",
    "allusion": "明神宗智擒宼準"
  },
  {
    "id": 17,
    "level": "上吉",
    "poem": "莫聽旁人說是非，主人自有一標枝。大抵福德由天定，不須作景反成憂。",
    "allusion": "話梅止渴"
  },
  {
    "id": 18,
    "level": "上上",
    "poem": "金烏西墜兔東升，日夜循環至古今。僧道得之無掛礙，凡人謀望總遂心。",
    "allusion": "曹國舅為仙"
  },
  {
    "id": 19,
    "level": "中平",
    "poem": "船離浪口百花開，涉水涉江亦無災。若是問前求富貴，三星照耀白人頭。",
    "allusion": "司馬太君逢難"
  },
  {
    "id": 20,
    "level": "中平",
    "poem": "當春久雨喜初晴，玉兔金烏漸漸明。舊事消散新事遂，看看得意向高前。",
    "allusion": "蘇武牧羊"
  },
  {
    "id": 21,
    "level": "上吉",
    "poem": "陰陽道合總由天，女嫁男婚喜事連。魚水相同幸福廣，大開門戶步青天。",
    "allusion": "李旦龍鳳配合"
  },
  {
    "id": 22,
    "level": "上吉",
    "poem": "四方各處盡亨通，萬里翱翔自作風。得意清名隨處顯，從今步步到天宮。",
    "allusion": "順治過關"
  },
  {
    "id": 23,
    "level": "中平",
    "poem": "欲計出行前路遙，勞心費力苦深焦。不如且守家門靜，免得隨風泛浪潮。",
    "allusion": "懷德招親"
  },
  {
    "id": 24,
    "level": "下下",
    "poem": "不須作景反成憂，戶內憂疑未見休。若問進前求富貴，三星照耀白人頭。",
    "allusion": "孟姜女尋夫"
  },
  {
    "id": 25,
    "level": "上吉",
    "poem": "過了憂煎萬事通，如同信步步天宮。寬心且住寬心坐，高才得意總相同。",
    "allusion": "姚能受職"
  },
  {
    "id": 26,
    "level": "中平",
    "poem": "上下不和同外人，萬事營謀未得成。若得貴人一指引，此去方知萬事通。",
    "allusion": "鍾馗得道"
  },
  {
    "id": 27,
    "level": "中平",
    "poem": "一謀一用總皆同，不用辛勤不費工。一箭射中雙飛鹿，東君福德大亨通。",
    "allusion": "垂德招親"
  },
  {
    "id": 28,
    "level": "下下",
    "poem": "東邊月上正西斜，此處營謀未見佳。若問前途何處好，三星照耀白人頭。",
    "allusion": "李后尋包公"
  },
  {
    "id": 29,
    "level": "中平",
    "poem": "寶劍出匣耀光明，在匣之時誰人知。今日得時提在手，三軍見之總低頭。",
    "allusion": "趙子龍救主"
  },
  {
    "id": 30,
    "level": "中平",
    "poem": "勸君切莫向他求，似水如登萬里秋。不如歇手閉門坐，免得隨風起閒愁。",
    "allusion": "楚懷王入秦"
  },
  {
    "id": 31,
    "level": "中平",
    "poem": "清淨身心寂寞坐，白雲依舊抱青松。世間萬事皆由天，不如歇手閉門眠。",
    "allusion": "佛印遇東坡"
  },
  {
    "id": 32,
    "level": "中平",
    "poem": "前途阻隔重重險，帶水拖泥步步難。若得貴人相引手，方知此去渡難關。",
    "allusion": "劉備求賢"
  },
  {
    "id": 33,
    "level": "中平",
    "poem": "自小生身富貴家，眼前事事總繁華。要知此去前程路，一到秋深見際涯。",
    "allusion": "咬金聘仁貴"
  },
  {
    "id": 34,
    "level": "中平",
    "poem": "行船流水兩無情，兩隻扁舟各自行。急流灘上難安穩，勸君切莫過前程。",
    "allusion": "桃園三結義"
  },
  {
    "id": 35,
    "level": "中平",
    "poem": "營謀不願意如心，此處何須苦認真。爭如靜坐閉門睡，免得隨風起閒愁。",
    "allusion": "唐僧取經"
  },
