    "allusion": "何文秀遇難"
  },
  {
    "id": 39,
    "level": "中平",
    "poem": "船離浪口百花開，涉水涉江亦無災。若是問前求富貴，三星照耀白人頭。",
    "allusion": "姜子牙五十歲成婚"
  },
  {
    "id": 40,
    "level": "上吉",
    "poem": "當春久雨喜初晴，玉兔金烏漸漸明。舊事消散新事遂，看看得意向高前。",
    "allusion": "武則天登基"
  },
  {
    "id": 41,
    "level": "中平",
    "poem": "無限好言君記取，卻為認賊將作子。莫貪眼下有些微，大抵非親防忌諱。",
    "allusion": "董卓收呂布"
  },
  {
    "id": 42,
    "level": "上吉",
    "poem": "君皇聖德及生民，祺祚繁昌萬紀新。甘露盤中迎曉日，象簪大帶步紅塵。",
    "allusion": "目連救母"
  },
  {
    "id": 43,
    "level": "上吉",
    "poem": "天地變通萬物新，自當出入最高鄰。刑名不用干防忌，一日清風向日新。",
    "allusion": "泗水關劉備得勝"
  },
  {
    "id": 44,
    "level": "中平",
    "poem": "棋逢敵手要藏機，黑白盤中未見稀。到底欲知誰勝負，須教用意著先機。",
    "allusion": "周瑜換計"
  },
  {
    "id": 45,
    "level": "上吉",
    "poem": "溫柔自古勝剛強，積善之門大吉祥。若是將心存正道，凡事安然免禍殃。",
    "allusion": "仁宗認母"
  },
  {
    "id": 46,
    "level": "中平",
    "poem": "勸君耐守舊生涯，把定心腸勿起邪。直待雲開見明月，依然光彩照蒼華。",
    "allusion": "渭水釣魚"
  },
  {
    "id": 47,
    "level": "上吉",
    "poem": "錦上添花色更鮮，運來祿馬喜雙全。時人莫恨功名晚，一舉登科四海傳。",
    "allusion": "高祖參拜韓信"
  },
  {
    "id": 48,
    "level": "中平",
    "poem": "崑鳥飛來化作鳳，老鵞腰下變做鸞。世間凡事皆由天，莫把心機百事瞞。",
    "allusion": "班超投筆從戎"
  },
  {
    "id": 49,
    "level": "下下",
    "poem": "營謀夜半強求孤，明月沉沉事總虛。若問前途何處好，三星照耀白人頭。",
    "allusion": "王祥臥冰"
  },
  {
    "id": 50,
    "level": "中平",
    "poem": "五湖四海盡亨通，萬里翱翔自作風。得意清名隨處顯，從今步步到天宮。",
    "allusion": "陶朱公九五歸家"
  },
  {
    "id": 51,
    "level": "上吉",
    "poem": "夏日初臨喜氣迎，如同瑞日向陽明。舊事消散新事遂，看看得意向高前。",
    "allusion": "諸葛亮孔明大婚"
  },
  {
    "id": 52,
    "level": "中平",
    "poem": "水中捉月費心機，費盡功夫卻是虛。不如且守家門靜，免得隨風汎浪潮。",
    "allusion": "太白撈月"
  },
  {
    "id": 53,
    "level": "中平",
    "poem": "王景與師一會同，不用辛勤不費工。一箭射中雙飛鹿，東君福德大亨通。",
    "allusion": "劉備入西川"
  },
  {
    "id": 54,
    "level": "下下",
    "poem": "東邊日出正西斜，此處營謀未見佳。若問前途何處好，三星照耀白人頭。",
    "allusion": "呂后害韓信"
  },
  {
    "id": 55,
    "level": "中平",
