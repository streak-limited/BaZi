    "id": 79,
    "level": "上吉",
    "poem": "莫聽旁人說是非，主人自有一標枝。大抵福德由天定，不須作景反成憂。",
    "allusion": "魏文帝稱帝"
  },
  {
    "id": 80,
    "level": "上上",
    "poem": "金烏西墜兔東升，日夜循環至古今。僧道得之無掛礙，凡人謀望總遂心。",
    "allusion": "智遠遇三娘"
  },
  {
    "id": 81,
    "level": "中平",
    "poem": "船離浪口百花開，涉水涉江亦無災。若是問前求富貴，三星照耀白人頭。",
    "allusion": "風送滕王閣"
  },
  {
    "id": 82,
    "level": "中平",
    "poem": "當春久雨喜初晴，玉兔金烏漸漸明。舊事消散新事遂，看看得意向高前。",
    "allusion": "楚霸王自烏江"
  },
  {
    "id": 83,
    "level": "中平",
    "poem": "無限好言君記取，卻為認賊將作子。莫貪眼下有些微，大抵非親防忌諱。",
    "allusion": "諸葛亮七擒孟獲"
  },
  {
    "id": 84,
    "level": "上吉",
    "poem": "君皇聖德及生民，祺祚繁昌萬紀新。甘露盤中迎曉日，象簪大帶步紅塵。",
    "allusion": "莊子試妻"
  },
  {
    "id": 85,
    "level": "上吉",
    "poem": "天地變通萬物新，自當出入最高鄰。刑名不用干防忌，一日清風向日新。",
    "allusion": "韓信掛帥"
  },
  {
    "id": 86,
    "level": "中平",
    "poem": "棋逢敵手要藏機，黑白盤中未見稀。到底欲知誰勝負，須教用意著先機。",
    "allusion": "商鞅變法"
  },
  {
    "id": 87,
    "level": "上吉",
    "poem": "溫柔自古勝剛強，積善之門大吉祥。若是將心存正道，凡事安然免禍殃。",
    "allusion": "咬金聘仁貴"
  },
  {
    "id": 88,
    "level": "中平",
    "poem": "勸君耐守舊生涯，把定心腸勿起邪。直待雲開見明月，依然光彩照蒼華。",
    "allusion": "張良隱退"
  },
  {
    "id": 89,
    "level": "上吉",
    "poem": "錦上添花色更鮮，運來祿馬喜雙全。時人莫恨功名晚，一舉登科四海傳。",
    "allusion": "大舜耕歷山"
  },
  {
    "id": 90,
    "level": "中平",
    "poem": "崑鳥飛來化作鳳，老鵞腰下變做鸞。世間凡事皆由天，莫把心機百事瞞。",
    "allusion": "韋佩聚仙"
  },
  {
    "id": 91,
    "level": "下下",
    "poem": "營謀夜半強求孤，明月沉沉事總虛。若問前途何處好，三星照耀白人頭。",
    "allusion": "三英戰呂布"
  },
  {
    "id": 92,
    "level": "中平",
    "poem": "五湖四海盡亨通，萬里翱翔自作風。得意清名隨處顯，從今步步到天宮。",
    "allusion": "蔡卿報恩"
  },
  {
    "id": 93,
    "level": "上吉",
    "poem": "夏日初臨喜氣迎，如同瑞日向陽明。舊事消散新事遂，看看得意向高前。",
    "allusion": "高祖稱帝"
  },
  {
    "id": 94,
    "level": "中平",
    "poem": "水中捉月費心機，費盡功夫卻是虛。不如且守家門靜，免得隨風汎浪潮。",
    "allusion": "西施歸五湖"
  },
  {
    "id": 95,
    "level": "中平",
    "poem": "王景與師一會同，不用辛勤不費工。一箭射中雙飛鹿，東君福德大亨通。",
    "allusion": "曹操得志"
  },
  {
    "id": 96,
    "level": "下下",
    "poem": "東邊日出正西斜，此處營謀未見佳。若問前途何處好，三星照耀白人頭。",
    "allusion": "竇燕山修善"
  },
  {
    "id": 97,
    "level": "中平",
    "poem": "寶劍出匣耀光明，在匣之時誰人知。今日得時提在手，三軍見之總低頭。",
    "allusion": "鄧通銅山鑄錢"
  },
  {
    "id": 98,
    "level": "中平",
    "poem": "勸君切莫向他求，似水如登萬里秋。不如歇手閉門坐，免得隨風起閒愁。",
    "allusion": "吉平下毒"
  },
  {
    "id": 99,
    "level": "中平",
    "poem": "清淨身心寂寞坐，白雲依舊抱青松。世間萬事皆由天，不如歇手閉門眠。",
    "allusion": "陶淵明賞菊"
  },
  {
    "id": 100,
    "level": "上上",
    "poem": "佛神護佑步青雲，一行策馬報功勳。三千法律皆歸一，富貴榮華到萬春。",
    "allusion": "唐明宗拜天"
  }
]