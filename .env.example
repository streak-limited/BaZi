# --- Gemini (AI Studio key; blocked from HK IP — use VPN for local dev, Vercel US for prod) ---
# Get key: https://aistudio.google.com/app/apikey
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
# gemini-1.5-flash is removed from API — use a current model (check ai.dev/rate-limit)
GEMINI_MODEL=gemini-3.1-flash-lite

# Turso (recommended on Vercel) — https://app.turso.tech
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token-from-create-token

# Local SQLite when TURSO_* unset (file:./data/bazi.db via libSQL)
# DATABASE_PATH=/app/data/bazi.db

# --- OpenAI (only if your region supports it; set AI_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o
