# --- Gemini (AI Studio key; blocked from HK IP — use VPN for local dev, Vercel US for prod) ---
# Get key: https://aistudio.google.com/app/apikey
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
# gemini-1.5-flash is removed from API — use a current model (check ai.dev/rate-limit)
GEMINI_MODEL=gemini-3.1-flash-lite

# Turso (recommended on Vercel) — https://app.turso.tech
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token-from-create-token

# Local SQLite when TURSO_* unset (file:./data/bazi.db via libSQL)
# DATABASE_PATH=/app/data/bazi.db

# --- Astrology (pyswisseph via Python subprocess) ---
# pip install -r requirements.txt  (or venv outside repo — see README)
# ASTROLOGY_PYTHON=/path/to/python-with-pyswisseph
# Optional high-precision ephemeris: SE_EPHE_PATH=/path/to/ephe
# ASTROLOGY_WEBHOOK_SECRET=your-random-secret-for-chart-save-webhook

# --- Stripe (pre-report paywall → full report) ---
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_AMOUNT_HKD=88          # used when STRIPE_PRICE_ID is unset (default 88)
# STRIPE_PRICE_ID=price_...     # optional: Dashboard → Products → Price ID
# STRIPE_PRODUCT_NAME=八字完整命理報告
# STRIPE_PRICE_LABEL=HK$299
# BAZI_SKIP_STRIPE=1            # force show “skip payment” button
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# --- Supabase (product flow: trials, payments, deliverables) ---
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# One-time schema: paste supabase/migrations/001_product_flow.sql in SQL Editor,
# or set DATABASE_URL (Dashboard → Database → URI) and run: npm run db:migrate
# DATABASE_URL=postgresql://postgres.[ref]:[password]@....pooler.supabase.com:6543/postgres
# RESEND_API_KEY=re_...           # report-ready email via Resend
# RESEND_FROM_EMAIL=BaZi <noreply@yourdomain.com>
# REPORT_GENERATION_DELAY_MS=5000 # 0 = instant (testing)
# USE_LIVE_AI_RESULT=1            # default off — result uses pre-report-analysis.json demo
# ADMIN_SECRET=your-local-admin-password   # /admin dashboard login
# USE_REAL_LISTING_IMAGES=1                # default off — home cards use picsum placeholders

# --- OpenAI (only if your region supports it; set AI_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o
